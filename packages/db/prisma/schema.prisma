datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum OrgRole {
  OWNER
  ADMIN
  MANAGER
  MEMBER
  VIEWER
}

model User {
  id             String          @id @default(uuid()) @db.Uuid
  email          String          @unique
  passwordHash   String
  name           String?
  isActive       Boolean         @default(true)
  lockedAt       DateTime?
  lastLoginAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?
  memberships    Member[]
  auditLogs      AuditLog[]
  refreshTokens  RefreshToken[]
  invitations    Invitation[]
  prompts        Prompt[]
  promptVersions PromptVersion[]

  @@map("users")
}

model Organization {
  id              String             @id @default(uuid()) @db.Uuid
  name            String
  slug            String             @unique
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?
  members         Member[]
  invitations     Invitation[]
  settings        OrganizationSettings?
  providerConfigs AiProviderConfig[]
  prompts         Prompt[]
  conversations   Conversation[]
  usageLogs       AiUsageLog[]

  @@map("organizations")
}

enum AiProvider {
  OPENAI
  ANTHROPIC
  GOOGLE
  AZURE_OPENAI
  OLLAMA
  CUSTOM
}

model OrganizationSettings {
  id                     String       @id @default(uuid()) @db.Uuid
  organizationId         String       @unique @db.Uuid
  timezone               String       @default("UTC")
  locale                 String       @default("en")
  logoUrl                String?
  brandingColor          String?
  defaultAiProvider      AiProvider?
  defaultAiModel         String?
  defaultAiTemperature   Float?
  defaultEmbeddingModel  String?
  allowPublicInvitations Boolean      @default(false)
  retentionDays          Int?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_settings")
}

model AiProviderConfig {
  id                   String         @id @default(uuid()) @db.Uuid
  organizationId       String         @db.Uuid
  provider             AiProvider
  name                 String
  encryptedCredentials String         // AES-256-GCM encrypted JSON payload
  defaultModel         String?
  temperature          Float?         @default(0.7)
  maxTokens            Int?           @default(2048)
  capabilities         String[]       @default([])
  isDefault            Boolean        @default(false)
  isActive             Boolean        @default(true)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  conversations        Conversation[]

  organization         Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("ai_provider_configs")
}

enum PromptVisibility {
  PRIVATE
  ORGANIZATION
  SYSTEM
}

enum PromptType {
  CHAT
  SYSTEM
  EMBEDDING
  COMPLETION
}

model PromptCategory {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  prompts     Prompt[]

  @@map("prompt_categories")
}

model Prompt {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String?          @db.Uuid // null for SYSTEM prompts
  categoryId     String           @db.Uuid
  name           String
  slug           String
  description    String?
  visibility     PromptVisibility @default(ORGANIZATION)
  type           PromptType       @default(CHAT)
  createdById    String           @db.Uuid
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?

  organization   Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category       PromptCategory   @relation(fields: [categoryId], references: [id])
  createdBy      User             @relation(fields: [createdById], references: [id])
  versions       PromptVersion[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("prompts")
}

model PromptVersion {
  id          String    @id @default(uuid()) @db.Uuid
  promptId    String    @db.Uuid
  version     Int       // integer version counter (e.g. 1, 2, 3)
  template    String
  changeLog   String?
  isActive    Boolean   @default(true)
  createdById String    @db.Uuid
  createdAt   DateTime  @default(now())
  messages    Message[]

  prompt      Prompt    @relation(fields: [promptId], references: [id], onDelete: Cascade)
  createdBy   User      @relation(fields: [createdById], references: [id])

  @@unique([promptId, version])
  @@map("prompt_versions")
}

enum ConversationStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum MessageRole {
  SYSTEM
  USER
  ASSISTANT
  TOOL
}

enum FinishReason {
  STOP
  LENGTH
  CONTENT_FILTER
  CANCELLED
  ERROR
  TOOL_CALL
}

enum AiRequestStatus {
  SUCCESS
  FAILED
  CANCELLED
  TIMEOUT
}

enum MemoryStrategy {
  SLIDING_WINDOW
  SUMMARY
  HYBRID
}

model Conversation {
  id               String              @id @default(uuid()) @db.Uuid
  organizationId   String              @db.Uuid
  title            String
  provider         AiProvider
  providerConfigId String              @db.Uuid
  model            String
  temperature      Float               @default(0.7)
  systemPrompt     String?
  status           ConversationStatus  @default(ACTIVE)
  memoryStrategy   MemoryStrategy      @default(SLIDING_WINDOW)
  summaryInterval  Int                 @default(20)
  maxContextTokens Int?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  deletedAt        DateTime?

  organization     Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  providerConfig   AiProviderConfig    @relation(fields: [providerConfigId], references: [id])
  messages         Message[]
  usageLogs        AiUsageLog[]
  summaries        ConversationSummary[]

  @@index([organizationId])
  @@map("conversations")
}

model ConversationSummary {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @db.Uuid
  version        Int
  summary        String
  startMessageId String?      @db.Uuid
  endMessageId   String?      @db.Uuid
  tokenCount     Int          @default(0)
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, version])
  @@map("conversation_summaries")
}

model Message {
  id                String        @id @default(uuid()) @db.Uuid
  conversationId    String        @db.Uuid
  role              MessageRole
  content           String
  promptVersionId   String?       @db.Uuid
  providerMessageId String?
  finishReason      FinishReason?
  latencyMs         Int?
  metadata          Json?
  createdAt         DateTime      @default(now())

  conversation      Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  promptVersion     PromptVersion? @relation(fields: [promptVersionId], references: [id])

  @@map("messages")
}

model AiUsageLog {
  id               String          @id @default(uuid()) @db.Uuid
  requestId        String          @unique @db.Uuid
  organizationId   String          @db.Uuid
  conversationId   String?         @db.Uuid
  providerConfigId String          @db.Uuid
  provider         AiProvider
  model            String
  promptTokens     Int             @default(0)
  completionTokens Int             @default(0)
  totalTokens      Int             @default(0)
  estimatedCostUsd Float           @default(0.0)
  status           AiRequestStatus
  errorCode        String?
  latencyMs        Int
  createdAt        DateTime        @default(now())

  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation     Conversation?   @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([providerConfigId])
  @@index([conversationId])
  @@index([status])
  @@index([model])
  @@map("ai_usage_logs")
}

model Member {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @db.Uuid
  organizationId String       @db.Uuid
  role           OrgRole      @default(MEMBER)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@map("members")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @db.Uuid
  action     String
  entityName String
  entityId   String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  userAgent String?
  ipAddress String?
  expiresAt     DateTime
  revokedAt     DateTime?
  revokedReason String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

model Invitation {
  id             String           @id @default(uuid()) @db.Uuid
  email          String
  role           OrgRole
  tokenHash      String           @unique
  status         InvitationStatus @default(PENDING)
  expiresAt      DateTime
  acceptedAt     DateTime?
  organizationId String           @db.Uuid
  invitedById    String           @db.Uuid
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?

  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy      User             @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([email, organizationId])
  @@map("invitations")
}
